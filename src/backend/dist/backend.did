  getAllSiteText: () -> (vec record {
                               text;
                               text;
                             }) query;
  getApprovedReviews: () -> (vec Review) query;
  getAvailability: () -> (AvailabilitySettings) query;
  getBlogPostBySlug: (slug: text) -> (opt BlogPost) query;
  getBuilds: () -> (vec Build);
