type http_request_result = 
 record {
   body: blob;
   headers: vec http_header;
   status: nat;
 };
type http_header = 
 record {
   name: text;
   value: text;
 };
type _ImmutableObjectStorageRefillResult = 
 record {
   success: opt bool;
   topped_up_amount: opt nat;
 };
type _ImmutableObjectStorageRefillInformation = record {
                                                  proposed_top_up_amount:
                                                   opt nat;};
type _ImmutableObjectStorageCreateCertificateResult = 
 record {
   blob_hash: text;
   method: text;
 };
type WeeklySchedule = 
 record {
   friday: DaySchedule;
   monday: DaySchedule;
   saturday: DaySchedule;
   sunday: DaySchedule;
   thursday: DaySchedule;
   tuesday: DaySchedule;
   wednesday: DaySchedule;
 };
type WebhookAuditEntry = 
 record {
   event_id: text;
   event_type: text;
   processing_result: text;
   received_at: int;
 };
type UserRole = 
 variant {
   admin;
   guest;
   user;
 };
type UserProfile = 
 record {
   businessName: text;
   businessType: text;
   created_at: Timestamp;
   email: text;
   firstName: text;
   lastName: text;
   passwordHash: blob;
   phone: text;
   role: text;
 };
type UpsertResult = 
 variant {
   err: text;
   ok;
   okAlreadyAdvanced;
 };
type TransformationOutput = 
 record {
   body: blob;
   headers: vec http_header;
   status: nat;
 };
type TransformationInput = 
 record {
   context: blob;
   response: http_request_result;
 };
type Timestamp = int;
type SubscriptionId = nat;
type Subscription = 
 record {
   billing_cycle: text;
   clientEmail: text;
   client_id: ClientId;
   created_at: Timestamp;
   id: SubscriptionId;
   nextBillingDate: int;
   next_payment_date: Timestamp;
   paymentFailed: bool;
   plan_code: text;
   plan_name: text;
   reminderSentAt: opt int;
   status: text;
   stripeCustomerId: opt text;
   stripe_subscription_id: text;
   updated_at: Timestamp;
 };
type SubAdmin = 
 record {
   allowedTabs: vec text;
   createdAt: int;
   email: text;
 };
type StripeSessionStatus = 
 variant {
   completed: record {
                response: text;
                userPrincipal: opt text;
              };
   failed: record {error: text;};
 };
type StripeConfiguration = 
 record {
   allowedCountries: vec text;
   secretKey: text;
 };
type Status = 
 variant {
   buildInProgress;
   cancelled;
   depositReceived;
   depositSent;
   draftReady;
   launching;
   live;
   paused;
   questionnaireComplete;
   questionnairePending;
   revisionsInProgress;
 };
type SocialMediaConfig = 
 record {
   facebookUrl: text;
   instagramUrl: text;
   linkedinUrl: text;
   tiktokUrl: text;
   youtubeUrl: text;
 };
type SiteLinkEntry = 
 record {
   sentAt: int;
   url: text;
 };
type ShoppingItem = 
