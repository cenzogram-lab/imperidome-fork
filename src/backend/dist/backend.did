 };
type ActivityId = nat;
service : {
  _immutableObjectStorageBlobsAreLive: (hashes: vec blob) -> (vec bool) query;
  _immutableObjectStorageBlobsToDelete: () -> (vec blob) query;
  _immutableObjectStorageConfirmBlobDeletion: (blobs: vec blob) -> ();
  _immutableObjectStorageCreateCertificate: (blobHash: text) ->
   (_ImmutableObjectStorageCreateCertificateResult);
  _immutableObjectStorageRefillCashier: (refillInformation:
   opt _ImmutableObjectStorageRefillInformation) ->
   (_ImmutableObjectStorageRefillResult);
  _immutableObjectStorageUpdateGatewayPrincipals: () -> ();
  _initializeAccessControl: () -> ();
  activateSubscription: (subscriptionId: text) ->
   (variant {
      err: text;
      ok: text;
    });
  addBuild: (clientName: text, siteUrl: text, description: opt text,
   category: opt text, thumbnailUrl: opt text) ->
   (variant {
      err: text;
      ok: Build;
    });
  addClient: (name: text, email: text, phone: text, source: text,
   activeServices: vec text, onboardingBriefId: opt text) -> (text);
  addFleetCanister: (name: text, canisterId: text) -> ();
  addFleetSite: (name: text, canisterId: text) -> ();
  addFleetSoftware: (name: text, canisterId: text) -> ();
  addMarqueeLogo: (logoUrl: text, logoLabel: text) ->
   (variant {
      err: text;
      ok: MarqueeLogo;
    });
  addSubAdmin: (email: text, tabs: vec text) -> (variant {
                                                   err: text;
                                                   ok;
                                                 });
  adminUpdateClientProfile: (clientId: text, firstName: text, lastName: 
   text, phone: text, businessName: text, businessType: text) ->
   (variant {
      err: text;
      ok: text;
    });
  approvePurchaseRequest: (requestId: nat, successUrl: text, cancelUrl:
   text) -> (variant {
               err: text;
               ok: text;
             });
  approveReview: (reviewId: ReviewId) -> (variant {
                                            err: text;
                                            ok;
                                          });
  assignCallerUserRole: (user: principal, role: UserRole) -> ();
  assignMeetingToLead: (leadId: text, newDate: text, newTime: text,
   meetingMethod: text) -> (record {
                              meetLink: text;
                              ok: bool;
                            });
  blockDate: (date: text) -> ();
  cancelEmailCampaign: (campaignId: nat) -> (variant {
                                               err: text;
                                               ok;
                                             });
  cancelSubscription: (subscriptionId: text) ->
   (variant {
      err: text;
      ok: text;
    });
  changePassword: (args:
   record {
     currentPasswordHash: blob;
     email: text;
     newPasswordHash: blob;
   }) -> (UpsertResult);
  checkStripeSessionPaid: (sessionId: text) ->
   (variant {
      error: text;
      notPaid;
      paid;
    });
  clearGoogleCalendarConfig: () -> (variant {
                                      err: text;
                                      ok;
                                    });
  clearGoogleSheetsConfig: () -> (variant {
                                    err: text;
                                    ok;
                                  });
  clearNotificationLog: () -> (variant {
                                 err: text;
                                 ok;
                               });
  clearPendingPushNotifications: () -> (variant {
                                          err: text;
                                          ok: text;
                                        });
  convertLeadToClient: (leadId: text, name: text, email: text, phone: 
   text, source: text, activeServices: vec text, onboardingBriefId:
   opt text) -> (text);
  createAdHocInvoiceSession: (clientId: text, description: text, amountCents:
   nat, successUrl: text, cancelUrl: text) -> (variant {
                                                 err: text;
                                                 ok: text;
                                               });
  createBlogPost: (title: text, slug: text, category: text, excerpt: 
   text, body: text, author: text, featured_image_url: opt text,
   featuredImageCaption: text, status: text, seoMetaDescription: opt text,
   seoMetaKeywords: opt text) -> (UpsertResult);
  createCheckoutSession: (items: vec ShoppingItem, clientEmail: text,
   successUrl: text, cancelUrl: text, clientName: text) ->
   (variant {
      err: text;
      ok: text;
    });
  createCompletionPaymentSession: (clientId: text, successUrl: text,
   cancelUrl: text) -> (text);
  createDraftLead: (name: text, email: text, phone: text, "service": 
   text) -> (record {
               leadId: text;
               ok: bool;
             });
  createEditRequest: (requestType: text, pageSection: text, description:
   text, attachmentUrl: text) -> (UpsertResult);
  createEmailCampaign: (subject: text, body: text, recipients: vec text,
   scheduledDate: opt int) -> (variant {
                                 err: text;
                                 ok: nat;
                               });
  createLead: (path: text, name: text, email: text, business: text, message:
   text) -> (text);
  createPortfolioItem: (client_name: text, site_url: text, thumbnail_url:
   text, imageCaption: text, tier_code: text, description: text, is_featured:
   bool, seoMetaDescription: opt text, seoMetaKeywords: opt text) ->
   (variant {
      err: text;
      ok: text;
    });
  createProduct: (name: text, description: text, productType: text,
   priceMonthly: opt float64, priceAnnual: opt float64, priceOnetime:
   opt float64, tagline: opt text, featureBullets: vec text, bestFor:
   opt text, upgradePath: opt text, recommendedPlan: opt text, paymentType:
   text, videoUrl1: text, videoUrl2: text, showQuestionnaire: bool,
   planSection: opt text, speedyFilter: opt text) ->
   (variant {
      err: text;
      ok: ProductId;
    });
  createPurchaseRequest: (clientEmail: text, productId: nat, frequency:
   text) -> (variant {
               err: text;
               ok: text;
             });
  createStripePaymentSession: (invoiceId: text, amountCents: nat, successUrl:
   text, cancelUrl: text) -> (variant {
                                err: text;
                                ok: text;
                              });
  createStripePortalSession: (callerEmail: text) ->
   (variant {
      err: text;
      ok: text;
    });
  declinePurchaseRequest: (requestId: nat, reason: opt text) ->
   (variant {
      err: text;
      ok: text;
    });
  deleteBlogPost: (id: BlogPostId) -> ();
  deleteBuild: (buildId: text) -> (variant {
                                     err: text;
                                     ok: bool;
                                   });
  deleteClient: (clientId: text) -> (variant {
                                       err: text;
                                       ok;
                                     });
  deleteClientFile: (fileId: text) -> (variant {
                                         err: text;
                                         ok: bool;
                                       });
  deleteLead: (leadId: text) -> ();
  deleteMarqueeLogo: (id: text) -> (variant {
                                      err: text;
                                      ok: bool;
                                    });
  deletePortfolioItem: (id: text) -> (UpsertResult);
  deleteProduct: (productId: nat) -> (variant {
                                        err: text;
                                        ok;
                                      });
  deleteQuestionnaire: (questionnaireId: QuestionnaireId) -> ();
  deleteReferral: (referralCode: text) -> (variant {
                                             err: text;
                                             ok;
                                           });
  deleteReview: (reviewId: ReviewId) -> (variant {
                                           err: text;
                                           ok;
                                         });
  editBuild: (id: text, clientName: text, siteUrl: text, description:
   opt text, category: opt text, thumbnailUrl: opt text) ->
   (variant {
      err: text;
      ok: Build;
    });
  generateAdminOTP: (adminEmail: text) -> (variant {
                                             err: text;
                                             ok: text;
                                           });
  generatePartnerLink: (partnerName: text, partnerEmail: text) -> (text);
  getAdHocClientInvoices: (clientId: text) -> (vec AdHocInvoice);
  getAdminAllActivity: () -> (vec ActivityLog) query;
  getAdminAllClients: () -> (vec UserProfile);
  getAdminAllOrders: () -> (vec Order) query;
