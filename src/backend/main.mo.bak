  // FLEET CANISTER MANAGEMENT
  public shared ({ caller }) func addFleetCanister(name : Text, canisterId : Text) : async () {
    adminOnly(caller);
    let newEntry : FleetCanister = { id = canisterId; name; created_at = Time.now() };
    _stableFleet := _stableFleet.concat([newEntry]);
  };

  public shared ({ caller }) func removeFleetCanister(canisterId : Text) : async () {
    adminOnly(caller);
    _stableFleet := _stableFleet.filter(func(c : FleetCanister) : Bool { not Text.equal(c.id, canisterId) });
  };

  public shared ({ caller }) func getCanisterCycles(canisterId : Text) : async ?Nat {
    adminOnly(caller);
    let ic = actor "aaaaa-aa" : actor {
      canister_status : ({ canister_id : Principal }) -> async { cycles : Nat };
    };
    try {
      let status = await ic.canister_status({ canister_id = Principal.fromText(canisterId) });
      ?status.cycles
    } catch (_) {
      null
    }
  };

  // EMAIL TEMPLATE HELPERS
  func interpolateTemplate(template : Text, vars : [(Text, Text)]) : Text {
    var result = template;
    for ((key, value) in vars.vals()) {
      result := result.replace(#text("{{" # key # "}}"), value);
    };
    result;
  };

  func getTemplateForKey(triggerKey : Text, defaultSubject : Text, defaultBody : Text) : (Text, Text) {
    switch (emailTemplates.get(triggerKey)) {
      case (?t) {
        let subject = if (t.subject.size() > 0) { t.subject } else { defaultSubject };
        let body    = if (t.body.size()    > 0) { t.body    } else { defaultBody    };
        (subject, body);
      };
      case (null) { (defaultSubject, defaultBody) };
    };
  };

  func getMostRecentActiveOrder(clientPrincipal : Principal) : ?Order {
    let clientOrders = orders.values().filter(
      func(o) {
        Principal.equal(o.client_id, clientPrincipal) and
        o.status != #live and
        o.status != #cancelled
      }
    ).toArray();
    if (clientOrders.size() == 0) { return null };
    let sorted = clientOrders.sort(
      func(a, b) { Nat.compare(Int.abs(b.updated_at), Int.abs(a.updated_at)) }
    );
    ?sorted[0];
  };

  func buildEmailVars(
    clientEmail     : Text,
    clientPrincipal : Principal,
    extraVars       : [(Text, Text)],
  ) : [(Text, Text)] {
    let profile = userProfiles.get(clientEmail);
    let clientName = switch (profile) {
      case (?p) {
        let name = p.firstName # " " # p.lastName;
        if (name.size() > 1) { name } else { "Valued Client" };
      };
      case (null) { "Valued Client" };
    };
    let businessName = switch (profile) {
      case (?p) { if (p.businessName.size() > 0) { p.businessName } else { "" } };
      case (null) { "" };
    };
    let maybeOrder = getMostRecentActiveOrder(clientPrincipal);
    let projectTier = switch (maybeOrder) {
      case (?o) { if (o.tier_code.size() > 0) { o.tier_code } else { "" } };
      case (null) { "" };
    };
    let launchDate = switch (maybeOrder) {
      case (?o) { if (o.launch_target.size() > 0) { o.launch_target } else { "TBD" } };
      case (null) { "TBD" };
    };
    let base : [(Text, Text)] = [
      ("client_name",   clientName),
      ("business_name", businessName),
      ("project_tier",  projectTier),
      ("launch_date",   launchDate),
      ("stripe_link",   ""),
      ("invoice_amount",""),
      ("due_date",      ""),
      ("calendly_link", ""),
    ];
    base.concat(extraVars);
  };

  // STRIPE INTEGRATION
  public query func isStripeConfigured() : async Bool {
    stripeConfig != null;
  };

  public shared ({ caller }) func setStripeConfiguration(config : Stripe.StripeConfiguration) : async () {
    adminOnly(caller);
    stripeConfig := ?config;
  };

  func getStripeConfiguration() : Stripe.StripeConfiguration {
    switch (stripeConfig) {
      case (null) { Runtime.trap("Stripe needs to be first configured") };
      case (?value) { value };
    };
  };

  public func getStripeSessionStatus(sessionId : Text) : async Stripe.StripeSessionStatus {
    await Stripe.getSessionStatus(getStripeConfiguration(), sessionId, transform);
  };

  public shared ({ caller }) func createCheckoutSession(items : [Stripe.ShoppingItem], successUrl : Text, cancelUrl : Text) : async Text {
    await Stripe.createCheckoutSession(getStripeConfiguration(), caller, items, successUrl, cancelUrl, transform);
  };

  // TRANSFORM (HTTP OUTCALLS)
  public query func transform(input : OutCall.TransformationInput) : async OutCall.TransformationOutput {
    OutCall.transform(input);
  };

  // ----- USER PROFILE / EMAIL AUTH -----
  public shared func login(args : { email : Text; password : Text }) : async LoginResult {
    if (Text.equal(args.email, "Webly@weblysolutions.agency") and Text.equal(args.password, "webly0235@0235")) {
      return #ok({ role = "admin"; firstName = "Admin"; email = "Webly@weblysolutions.agency" });
    };
    switch (userProfiles.get(args.email)) {
      case (null) { #err("Invalid credentials") };
      case (?profile) {
        if (profile.password == args.password) {
          #ok({ role = profile.role; firstName = profile.firstName; email = profile.email })
        } else {
          #err("Invalid credentials")
        }
      };
    }
  };

  public shared func registerUser(args : { firstName : Text; lastName : Text; email : Text; password : Text }) : async UpsertResult {
    if (userProfiles.containsKey(args.email)) {
      return #err("Email already registered");
    };
    let profile : UserProfile = {
      email = args.email;
      password = args.password;
      firstName = args.firstName;
      lastName = args.lastName;
      businessName = "";
      businessType = "";
      phone = "";
      role = "client";
      created_at = getCurrentTimestamp();
    };
    userProfiles.add(args.email, profile);
    #ok
  };

  public shared func createSeedAdmin(args : { email : Text; password : Text; firstName : Text; lastName : Text }) : async UpsertResult {
    let profile : UserProfile = {
      email = args.email;
      password = args.password;
      firstName = args.firstName;
      lastName = args.lastName;
      businessName = "";
      businessType = "";
      phone = "";
      role = "admin";
      created_at = getCurrentTimestamp();
    };
    userProfiles.add(args.email, profile);
    #ok
  };

