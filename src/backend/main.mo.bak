  // LEADS
  public shared func createLead(path : Text, name : Text, email : Text, business : Text, message : Text) : async Text {
    let id = Time.now().toText();
    let lead : Lead = { id; path; name; email; business; message; status = "new"; created_at = Time.now(); };
    _stableLeads := _stableLeads.concat([(id, lead)]);
    id;
  };

  public query func getLeads() : async [Lead] {
    _stableLeads.map(func((_, lead) : (Text, Lead)) : Lead { lead });
  };

  // ORDERS ADMIN
  private func textToOrderStatus(s : Text) : OrderStatus.Status {
    if (s == "depositSent")       { #depositSent }
    else if (s == "depositReceived") { #depositReceived }
    else if (s == "draftReady")   { #draftReady }
    else if (s == "revisionsInProgress") { #revisionsInProgress }
    else if (s == "launching")    { #launching }
    else if (s == "live")         { #live }
    else if (s == "cancelled")    { #cancelled }
    else                          { #questionnaireComplete };
  };

  public query func getAdminAllOrders() : async [Order] {
    orders.values().toArray();
  };

  public shared func updateOrderStatus(orderId : Text, newStatus : Text) : async UpsertResult {
    switch (Nat.fromText(orderId)) {
      case null { #err("Invalid orderId") };
      case (?id) {
        switch (orders.get(id)) {
          case null { #err("Order not found") };
          case (?order) {
            let updated = { order with status = textToOrderStatus(newStatus); updated_at = Time.now() };
            orders.add(id, updated);
            #ok;
          };
        };
      };
    };
  };

  // PORTFOLIO
  public query func getPublishedPortfolio() : async [PortfolioItem] {
    portfolio.values().toArray();
  };

  public shared func createPortfolioItem(client_name : Text, site_url : Text, thumbnail_url : Text, tier_code : Text, description : Text, is_featured : Bool) : async Text {
    let id = Time.now().toText();
    portfolio.add(id, { id; client_name; site_url; thumbnail_url; tier_code; description; is_featured; created_at = Time.now() });
    id;
  };

  public shared func updatePortfolioItem(id : Text, client_name : Text, site_url : Text, thumbnail_url : Text, tier_code : Text, description : Text, is_featured : Bool) : async UpsertResult {
    switch (portfolio.get(id)) {
      case null { #err("Not found") };
      case (?old) { portfolio.add(id, { old with client_name; site_url; thumbnail_url; tier_code; description; is_featured }); #ok };
    };
  };

  public shared func deletePortfolioItem(id : Text) : async UpsertResult {
    switch (portfolio.get(id)) {
      case null { #err("Not found") };
      case (?_) { portfolio.remove(id); #ok };
    };
  };

  // UPGRADE HOOKS
  system func preupgrade() {
    _stableOrders         := orders.values().toArray();
    _stableActivities     := activities.values().toArray();
    _stableQuestionnaires := questionnaires.values().toArray();
    _stableSubscriptions  := subscriptions.values().toArray();
    _stableBillingHistory := billingHistory.values().toArray();
    _stableInvoices       := invoices.values().toArray();
    _stableEditRequests   := editRequests.values().toArray();
    _stableBlogPosts      := blogPosts.values().toArray();
    _stableEmailTemplates := emailTemplates.values().toArray();
    _stableUserProfiles   := userProfiles.values().toArray();
    _stableProducts       := [];
    _stablePortfolio      := portfolio.entries().toArray();
  };

  system func postupgrade() {
    for (v in _stableOrders.vals())         { orders.add(v.id, v) };
    for (v in _stableActivities.vals())     { activities.add(v.id, v) };
    for (v in _stableQuestionnaires.vals()) { questionnaires.add(v.id, v) };
    for (v in _stableSubscriptions.vals())  { subscriptions.add(v.id, v) };
    for (v in _stableBillingHistory.vals()) { billingHistory.add(v.id, v) };
    for (v in _stableInvoices.vals())       { invoices.add(v.id, v) };
    for (v in _stableEditRequests.vals())   { editRequests.add(v.id, v) };
    for (v in _stableBlogPosts.vals()) {
      blogPosts.add(v.id, v);
      slugIndex.add(v.slug, v.id);
    };
    for (v in _stableEmailTemplates.vals()) { emailTemplates.add(v.trigger_key, v) };
    for (v in _stableUserProfiles.vals())   { userProfiles.add(v.email, v) };
    for ((k, v) in _stableProducts.vals()) {
      productCatalog.add(k, {
        id            = v.id;
        name          = v.name;
        tier_code     = null;
        product_type  = v.product_type;
        price_monthly = v.price_monthly;
        price_annual  = v.price_annual;
        price_onetime = v.price_onetime;
        active        = v.active;
        created_at    = v.created_at;
      });
    };
    if (productCatalog.size() == 0) { _seedProducts() };
    for ((k, v) in _stablePortfolio.vals()) { portfolio.add(k, v) };
    _stableOrders         := [];
    _stableActivities     := [];
    _stableQuestionnaires := [];
    _stableSubscriptions  := [];
    _stableBillingHistory := [];
    _stableInvoices       := [];
    _stableEditRequests   := [];
    _stableBlogPosts      := [];
    _stableEmailTemplates := [];
    _stableUserProfiles   := [];
    _stableProducts       := [];
    _stablePortfolio      := [];
    if (not userProfiles.containsKey("Webly@weblysolutions.agency")) {
      userProfiles.add("Webly@weblysolutions.agency", {
        email        = "Webly@weblysolutions.agency";
        password     = "webly0235@0235";
        firstName    = "Admin";
        lastName     = "Webly";
        businessName = "";
        businessType = "";
        phone        = "";
        role         = "admin";
        created_at   = 0;
      });
    };
  };
};
