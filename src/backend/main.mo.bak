  stable var _stableSubscriptions : [Subscription] = [];
  stable var _stableBillingHistory : [BillingHistory] = [];
  stable var _stableInvoices : [Invoice] = [];
  stable var _stableEditRequests : [EditRequest] = [];
  stable var _stableBlogPosts : [BlogPost] = [];
  stable var _stableEmailTemplates : [EmailTemplate] = [];
  stable var _stableUserProfiles : [UserProfile] = [];
  stable var _stableLeads : [(Text, Lead)] = [];
  stable var _stableProducts : [(Nat, ProductV1)] = [];
  stable var _stablePortfolio : [(Text, PortfolioItem)] = [];

