   currency: text;
   priceInCents: nat;
   productDescription: text;
   productName: text;
   quantity: nat;
 };
type ReviewId = text;
type Review = 
 record {
   clientEmail: text;
   clientName: text;
   id: ReviewId;
   jobTitle: text;
   rating: nat;
   reviewText: text;
   status: text;
   submittedAt: int;
 };
type ReferralStat = 
